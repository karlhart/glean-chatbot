# Glean instance (the subdomain of your Glean deployment)
GLEAN_INSTANCE=your-instance-name

# Glean API Tokens
GLEAN_INDEXING_TOKEN=your-indexing-api-token-here
GLEAN_CLIENT_TOKEN=your-client-api-token-here

# Datasource to index documents into (one of: interviewds, interviewds2, ..., interviewds6)
GLEAN_DATASOURCE=interviewds

# Optional: email to impersonate for user-scoped API calls (leave blank for global token behaviour)
GLEAN_ACT_AS=user@your-domain.com
